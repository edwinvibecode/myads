generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique 
  passwordHash  String
  twoFactorSecret String?      // Base32 encoded TOTP secret
  twoFactorEnabled Boolean    @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  domains       Domain[]
  revenues      RevenueEntry[]
  expenses      Expense[]
  exchangeRates ExchangeRate[]
  adProviders   AdProvider[]
}

model Domain {
  id         Int            @id @default(autoincrement())
  userId     Int
  name       String         
  slug       String         
  isArchived Boolean        @default(false)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  adProviders AdProvider[]
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  revenues   RevenueEntry[]
  expenses   Expense[]

  @@unique([userId, slug])
  @@index([userId])
}

model RevenueEntry {
  id        Int      @id @default(autoincrement())
  userId    Int
  domainId  Int
  network   String   @default("CLICKADILLA")
  amount    Decimal  
  currency  String   @default("USD")
  month     Int
  year      Int
  notes     String?  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain    Domain   @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@index([userId, year, month])
  @@index([domainId, year, month])
}

model Expense {
  id          Int         @id @default(autoincrement())
  userId      Int
  domainId    Int?
  type        String   @default("OPERATIONAL")
  category    String   
  description String?   
  amount      Decimal  
  currency    String   @default("USD")
  date        DateTime    
  isRecurring Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain      Domain?     @relation(fields: [domainId], references: [id], onDelete: SetNull)

  @@index([userId, date])
}

model ExchangeRate {
  id            Int      @id @default(autoincrement())
  userId        Int
  fromCurrency  String   @default("USD")
  toCurrency    String   @default("IDR")
  rate          Decimal  
  effectiveDate DateTime 
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fromCurrency, toCurrency, effectiveDate])
}

model LoginAttempt {
  id        Int      @id @default(autoincrement())
  email     String   
  ip        String   
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ip, createdAt])
}

model AdProvider {
  id        Int       @id @default(autoincrement())
  userId    Int
  domainId  Int
  name      String    // "Adsterra", "Clickadilla", "Clickadu"
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain    Domain    @relation(fields: [domainId], references: [id], onDelete: Cascade)
  codes     AdCode[]

  @@index([userId, domainId])
  @@unique([userId, domainId, name])
}

model AdCode {
  id          Int        @id @default(autoincrement())
  providerId  Int
  name        String     // "Banner 300x250", "Popunder"
  format      String     // "banner", "popunder", "inpage", "native"
  htmlCode    String     @db.Text
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  provider    AdProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
}

